{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcp-2099.local/contracts/agent-platform/v1/agent-run.schema.json",
  "title": "AgentRun",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "taskId", "role", "label", "status", "progress", "dependsOn"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "parentId": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "status": { "enum": ["pending", "running", "waiting", "completed", "failed", "cancelled"] },
    "progress": { "type": "number", "minimum": 0, "maximum": 100 },
    "dependsOn": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "summary": { "type": "string", "maxLength": 4000 },
    "startedAt": { "type": "string", "format": "date-time" },
    "finishedAt": { "type": "string", "format": "date-time" }
  }
}
